{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "R: Install Package",
      "type": "shell",
      "command": "${workspaceFolder}/.pixi/envs/default/bin/R CMD INSTALL .",
      "problemMatcher": ["$gcc"],
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "R: Run Tests",
      "type": "shell",
      "command": "${workspaceFolder}/.pixi/envs/default/bin/R -e 'devtools::test()'",
      "problemMatcher": ["$gcc"],
      "group": "test",
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "R: Generate Docs",
      "type": "shell",
      "command": "${workspaceFolder}/.pixi/envs/default/bin/R -e 'devtools::document()'",
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "R: Check Package",
      "type": "shell",
      "command": "${workspaceFolder}/.pixi/envs/default/bin/R CMD check .",
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "C: Syntax Check",
      "type": "shell",
      "command": "gcc -fsyntax-only -c ${file} -I${workspaceFolder}/.pixi/envs/default/lib/R/include -I${workspaceFolder}/.pixi/envs/default/include -I${workspaceFolder}/src",
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}